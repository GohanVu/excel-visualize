generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

enum SubscriptionPlan {
  free
  pro
}

enum SubscriptionStatus {
  active
  canceled
  past_due
}

enum ColumnType {
  date
  number
  string
  category
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  avatarUrl            String?
  role                 Role      @default(user)
  googleId             String?   @unique
  encryptedRefreshToken String?
  passwordHash         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  datasets      Dataset[]
  dashboards    Dashboard[]
  subscription  Subscription?
  auditLogs     AuditLog[]

  @@map("users")
}

// ─── Datasets ─────────────────────────────────────────────────────────────────

model Dataset {
  id           String   @id @default(cuid())
  userId       String
  name         String
  originalName String
  mimeType     String
  sizeBytes    Int
  minioKey     String
  rowCount     Int?
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns DatasetColumn[]
  charts  Chart[]

  @@map("datasets")
}

model DatasetColumn {
  id        String     @id @default(cuid())
  datasetId String
  name      String
  type      ColumnType
  position  Int

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@map("dataset_columns")
}

// ─── Dashboards & Charts ──────────────────────────────────────────────────────

model Dashboard {
  id     String @id @default(cuid())
  userId String
  name   String @default("Dashboard mới")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  charts Chart[]

  @@map("dashboards")
}

model Chart {
  id          String @id @default(cuid())
  dashboardId String
  datasetId   String
  type        String
  title       String?
  config      Json
  position    Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  dataset   Dataset   @relation(fields: [datasetId], references: [id], onDelete: Restrict)

  @@map("charts")
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
