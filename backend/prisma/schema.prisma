generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

enum SubscriptionPlan {
  free
  pro
}

enum SubscriptionStatus {
  active
  canceled
  past_due
}

enum ColumnType {
  date
  number
  string
  category
}

enum StudyStatus {
  new
  learning
  known
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  avatarUrl            String?
  role                 Role      @default(user)
  googleId             String?   @unique
  encryptedRefreshToken String?
  passwordHash         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  datasets            Dataset[]
  dashboards          Dashboard[]
  subscription        Subscription?
  auditLogs           AuditLog[]
  studyProgress       StudyProgress[]
  paymentTransactions PaymentTransaction[]

  @@map("users")
}

// ─── Datasets ─────────────────────────────────────────────────────────────────

model Dataset {
  id                  String          @id @default(cuid())
  userId              String
  name                String
  originalName        String
  mimeType            String
  sizeBytes           Int
  minioKey            String
  rowCount            Int?
  lastSyncedAt        DateTime?
  googleSpreadsheetId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns       DatasetColumn[]
  charts        Chart[]
  studyProgress StudyProgress[]

  @@map("datasets")
}

model DatasetColumn {
  id        String     @id @default(cuid())
  datasetId String
  name      String
  type      ColumnType
  position  Int

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@map("dataset_columns")
}

// ─── Dashboards & Charts ──────────────────────────────────────────────────────

model Dashboard {
  id     String @id @default(cuid())
  userId String
  name   String @default("Dashboard mới")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  charts Chart[]

  @@map("dashboards")
}

model Chart {
  id          String @id @default(cuid())
  dashboardId String
  datasetId   String
  type        String
  title       String?
  config      Json
  position    Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  dataset   Dataset   @relation(fields: [datasetId], references: [id], onDelete: Restrict)

  @@map("charts")
}

// ─── Study Progress (Learning Mode) ──────────────────────────────────────────

model StudyProgress {
  id        String      @id @default(cuid())
  userId    String
  datasetId String
  sheet     String      @default("") // tab (worksheet); "" = tab mặc định/đầu
  cardKey   String // định danh thẻ (vd hash giá trị dòng) — ổn định qua re-parse
  status    StudyStatus @default(new)
  seenCount Int         @default(0)
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  // Mỗi user × dataset × tab × thẻ chỉ 1 bản ghi tiến độ
  @@unique([userId, datasetId, sheet, cardKey])
  @@map("study_progress")
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  plan            SubscriptionPlan   @default(free)
  status          SubscriptionStatus @default(active)
  paymentProvider String             @default("payos")
  expiredAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model PaymentTransaction {
  id             String   @id @default(cuid())
  userId         String
  orderCode      Int      @unique
  amount         Int
  durationMonths Int
  status         String   @default("PENDING") // PENDING, PAID, CANCELLED
  paymentLinkId  String?
  checkoutUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
