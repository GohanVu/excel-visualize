# Copy file này thành .env và điền giá trị thật
# cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=changeme_local
DATABASE_URL=postgresql://chartly:changeme_local@localhost:5433/chartly

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_local

# JWT — sinh bằng: openssl rand -hex 64
JWT_SECRET=change_this_to_random_secret
JWT_REFRESH_SECRET=change_this_to_another_random_secret

# Google OAuth — lấy từ Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Claude API (để trống nếu chưa dùng AI feature)
CLAUDE_API_KEY=

# Frontend
VITE_API_URL=http://localhost:3000
